# ---- Express API server (server/index.js) ----
# AI Provider Configuration
DEFAULT_AI_PROVIDER=gemini
LOCAL_MODEL=llama3.2:1b
OLLAMA_URL=http://127.0.0.1:11434

# Development Flag (Set to true to bypass backend authentication for AI generation)
DEV_AUTH_BYPASS=true

# The Gemini key lives ONLY here, server-side. Leave unset to run without AI
# (the app falls back to Simulator/fallback content with visible warnings).
GEMINI_API_KEY=
PORT=8787
# Supabase project the server talks to (defaults are built in for this repo's instance)
SUPABASE_URL=https://ymxxxfvxjheaiacddcfa.supabase.co
SUPABASE_KEY=sb_publishable_LRNsxU4hCSXDNnxSRlii4A_QuqIlY9w

# ---- Vite frontend (browser-safe, publishable values only) ----
# Used solely for the Supabase auth handshake (magic link + session).
VITE_SUPABASE_URL=https://ymxxxfvxjheaiacddcfa.supabase.co
VITE_SUPABASE_KEY=sb_publishable_LRNsxU4hCSXDNnxSRlii4A_QuqIlY9w
