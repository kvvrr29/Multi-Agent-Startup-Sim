{
  "name": "multi-agent-startup-simulator",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run src",
    "test:e2e": "playwright test",
    "test:live": "vitest run tests/live/gemini.live.test.js --testTimeout=180000",
    "check": "npm run lint && npm run test:unit && npm run build && npm run test:e2e",
    "server": "node server/index.js",
    "dev:full": "concurrently -n api,web -c blue,green \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "@supabase/supabase-js": "^2.110.7",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "docx": "^9.7.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.41.0",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.21.0",
    "mermaid": "^11.15.0",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.10"
  }
}
